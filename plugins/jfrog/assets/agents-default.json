{
  "logLevel": "info",
  "packageGuard": {
    "enabled": false,
    "verifyRepos": true,
    "cacheTtlDays": 7,
    "defaultGlobalRepos": {
      "npm": "npm-virtual",
      "pypi": "pypi-virtual",
      "maven": "maven-virtual",
      "go": "go-virtual",
      "docker": "docker-virtual",
      "helm": "helm-virtual",
      "nuget": "nuget-virtual"
    }
  }
}
